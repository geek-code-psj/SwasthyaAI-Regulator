# ENVIRONMENT CONFIGURATION
FLASK_ENV=development
FLASK_APP=backend/app.py

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/swastya_regulator

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production

# FILE UPLOADS
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=104857600
ALLOWED_EXTENSIONS=pdf,jpg,png,jpeg,tif,tiff

# OCR SETTINGS
OCR_LANGUAGE=eng
TESSERACT_PATH=/usr/bin/tesseract

# ANONYMIZATION
ANONYMIZATION_VAULT_PATH=./vault
DATA_RETENTION_DAYS=90
K_ANONYMITY_THRESHOLD=5
L_DIVERSITY_THRESHOLD=2
T_CLOSENESS_THRESHOLD=0.15

# SUMMARIZATION
SUMMARIZATION_MODEL=facebook/bart-large-cnn
SUMMARIZATION_MAX_LENGTH=150
SUMMARIZATION_MIN_LENGTH=50

# REDIS (for Celery)
REDIS_URL=redis://localhost:6379/0

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# DEPLOYMENT
APP_HOST=0.0.0.0
APP_PORT=5000
DEBUG=False
